            <label>Ingrese un primer valor:</label>
            <input type="number" name="value1">

            <label>Ingrese un segundo valor:</label>
            <input type="number" name="value2">
            <button type="submit" class="formulary-button">Enviar ✅</button>
            
         
        </form>

        {% if resultado is not none %}
            <p>El resultado es {{ resultado }}</p>
        {% endif %}


        
    </div>
    </body>
</html>"""